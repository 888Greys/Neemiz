# ── Neemiz signer env (soi only) ──────────────────────────────────────────────
# THIS HOST IS THE ONLY PLACE THE SEED LIVES. Do not put the seed on nez.

# The rotated master mnemonic (NEVER commit, NEVER on the web app)
MASTER_WALLET_MNEMONIC="word word word ... word"

# Shared secret for HMAC auth with nez. Generate: openssl rand -hex 32
# Must match SIGNER_HMAC_SECRET on nez.
SIGNER_HMAC_SECRET="<64 hex chars>"

# Bind address. In prod, bind to the WireGuard interface IP so the signer is
# never reachable on the public internet (e.g. 10.8.0.2). Port is not published.
SIGNER_BIND=10.8.0.2
SIGNER_PORT=8787

# Reject requests whose timestamp is older/newer than this (ms)
SIGNER_MAX_SKEW_MS=90000

# Where daily-cap + idempotency state is stored (mount a volume here)
SIGNER_STATE_DIR=/data

# ── Spend caps (independent of nez; fail-closed) ──────────────────────────────
# JSON maps; DEFAULT applies to any crypto not listed. Amounts are per-crypto.
SIGNER_PER_TX_CAP={"DEFAULT":1000,"USDT":1000,"USDC":1000}
SIGNER_DAILY_CAP={"DEFAULT":2000,"USDT":2000,"USDC":2000}
# Optional: above this, refuse with APPROVAL_REQUIRED (manual handling). Empty = off.
SIGNER_APPROVAL_THRESHOLD={}

# ── Telegram alerts (every sign + every block) ────────────────────────────────
SIGNER_TG_BOT_TOKEN=
SIGNER_TG_CHAT_ID=

# ── Optional RPC overrides + Tron gas tuning ──────────────────────────────────
# RPC_ERC20=
# RPC_BEP20=
# RPC_POLYGON=
# TRONGRID_API_KEY=
# TRON_MIN_GAS_TRX=15
# TRON_GAS_TOPUP_TRX=20
