{
  "name": "neemiz",
  "version": "1.10.0",
  "private": true,
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || true",
    "dev": "next dev --turbo",
    "dev:turbo": "next dev --turbo",
    "dev:fast": "set NEXT_PUBLIC_DEV_FAST=1&& next dev --turbo",
    "check": "prisma validate && tsc --noEmit",
    "check:types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:accumulator": "vitest run tests/accumulator.test.ts",
    "test:fairness": "vitest run tests/fairness.test.ts",
    "fairness:live": "bunx tsx scripts/fairness-sim.ts",
    "pricing:proof": "bunx tsx scripts/pricing-proof.ts",
    "build:no-generate": "next build",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "bunx prisma generate",
    "db:push": "bunx prisma db push",
    "db:migrate": "bunx prisma migrate dev",
    "db:studio": "bunx prisma studio",
    "seed:local": "bunx tsx --env-file=.env scripts/seed-local.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1077.0",
    "@getbrevo/brevo": "^2.2.0",
    "@polymarket/clob-client-v2": "^1.0.6",
    "@prisma/client": "^6.8.2",
    "@sentry/nextjs": "^10.56.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.2",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.0",
    "ethers": "^6.13.5",
    "lightweight-charts": "^5.2.0",
    "lucide-react": "^1.16.0",
    "neemiz-binary-engine": "^1.0.1",
    "next": "14.2.35",
    "prisma": "^6.8.2",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "recharts": "^3.8.1",
    "redis": "^4.7.1",
    "sharp": "^0.35.1",
    "simple-icons": "^16.24.1",
    "sonner": "^2.0.7",
    "twilio": "^6.0.2",
    "viem": "^2.50.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.35",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.7.2",
    "vitest": "^3.2.6"
  }
}
