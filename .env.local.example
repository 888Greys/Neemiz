# ─── Supabase Auth ───────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_WEBHOOK_SECRET=generate_a_strong_shared_secret

# ─── PostgreSQL (your VPS) ────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@YOUR_VPS_IP:5432/DATABASE_NAME
DATABASE_URL=postgresql://neemiz:yourpassword@123.456.789.0:5432/neemiz

# ─── Brevo ───────────────────────────────────────────────────────────────────
# Get from https://app.brevo.com → SMTP & API → API Keys
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BREVO_SENDER_EMAIL=noreply@yourdomain.com
BREVO_SENDER_NAME=Neemiz

# ─── The Odds API ────────────────────────────────────────────────────────────
# Get from https://the-odds-api.com → Dashboard
ODDS_API_KEY=your_odds_api_key_here

# ─── MegaPay ─────────────────────────────────────────────────────────────────
# Get from https://megapay.co.ke/user/index → API Settings
MEGAPAY_BASE_URL=https://megapay.co.ke
MEGAPAY_API_KEY=your_megapay_api_key_here
MEGAPAY_EMAIL=your_megapay_account_email_here
MEGAPAY_CALLBACK_URL=https://www.nezeem.com/api/webhooks/megapay
MEGAPAY_CALLBACK_TOKEN=generate_a_strong_shared_secret

# ─── Crypto Deposit Addresses (HD Wallet) ────────────────────────────────────
# 12-word BIP39 mnemonic — KEEP SECRET, never commit the real value
MASTER_WALLET_MNEMONIC="word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12"

# Etherscan API V2 — covers ETH (chainId=1) and BSC (chainId=56)
# Get free key at https://etherscan.io/myapikey
ETHERSCAN_API_KEY=your_etherscan_api_key

# TronGrid — for TRC20 USDT deposits
# Get free key at https://www.trongrid.io/dashboard
TRONGRID_API_KEY=your_trongrid_api_key

# Moralis Streams — webhook-first EVM deposit detection for ERC20/BEP20/POLYGON
# Webhook URL: https://www.nezeem.com/api/webhooks/moralis
MORALIS_API_KEY=your_moralis_api_key
MORALIS_EVM_STREAM_ID=your_moralis_evm_stream_id
MORALIS_STREAM_SECRET=your_moralis_stream_secret

# Tatum Notifications — webhook-first BTC/TRC20 deposit detection
# Webhook URL: https://www.nezeem.com/api/webhooks/tatum
# Enable HMAC in Tatum with this same secret, then sync existing addresses via:
#   GET /api/cron/sync-tatum-addresses
TATUM_API_KEY=your_tatum_api_key
TATUM_WEBHOOK_SECRET=your_tatum_hmac_secret

# ─── Bet Settlement Cron / Workers ───────────────────────────────────────────
# Generate with: openssl rand -hex 32
# Used by VPS cron: curl -H "Authorization: Bearer YOUR_SECRET" https://nezeem.com/api/cron/check-deposits
CRON_SECRET=your_strong_random_secret_here
SETTLE_SECRET=your_polymarket_settlement_secret

# ─── Polymarket Predictions ─────────────────────────────────────────────────
# Keep "internal" for real Polymarket market data with Nezeem-only balances,
# positions, and payouts. Use "clob" only when intentionally placing real
# Polymarket orders from a funded Polymarket trading wallet.
POLYMARKET_TRADING_MODE=internal

# Only required when POLYMARKET_TRADING_MODE=clob.
POLYMARKET_CLOB_HOST=https://clob.polymarket.com
POLYMARKET_CHAIN_ID=137
POLYMARKET_PRIVATE_KEY=0x_your_trading_wallet_private_key
POLYMARKET_SIGNATURE_TYPE=0
POLYMARKET_FUNDER_ADDRESS=
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_DERIVE_API_KEY=false
POLYMARKET_ORDER_TYPE=FOK
POLYMARKET_TICK_SIZE=0.01
POLYMARKET_RPC_URL=

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Sentry Monitoring ──────────────────────────────────────────────────────
# Create a Next.js project at https://sentry.io and copy its DSN.
NEXT_PUBLIC_SENTRY_DSN=https://public_key@o0.ingest.sentry.io/project_id
SENTRY_DSN=https://public_key@o0.ingest.sentry.io/project_id
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_TRACES_SAMPLE_RATE=0.1

# Required only for uploading readable production source maps during builds.
SENTRY_ORG=your_sentry_org_slug
SENTRY_PROJECT=your_sentry_project_slug
SENTRY_AUTH_TOKEN=your_sentry_auth_token

# ─── Standalone Aviator Engine ───────────────────────────────────────────────
AVIATOR_SERVICE_URL=https://aviator.nezeem.com
AVIATOR_SERVICE_SECRET=generate_a_strong_shared_secret
NEXT_PUBLIC_AVIATOR_WS_URL=wss://aviator.nezeem.com/ws
