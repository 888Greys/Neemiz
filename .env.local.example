# ─── Supabase Auth ───────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_WEBHOOK_SECRET=generate_a_strong_shared_secret

# ─── PostgreSQL (your VPS) ────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@YOUR_VPS_IP:5432/DATABASE_NAME
DATABASE_URL=postgresql://neemiz:yourpassword@123.456.789.0:5432/neemiz

# ─── Brevo ───────────────────────────────────────────────────────────────────
# Get from https://app.brevo.com → SMTP & API → API Keys
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BREVO_SENDER_EMAIL=noreply@yourdomain.com
BREVO_SENDER_NAME=Neemiz

# ─── The Odds API ────────────────────────────────────────────────────────────
# Get from https://the-odds-api.com → Dashboard
ODDS_API_KEY=your_odds_api_key_here

# ─── MegaPay ─────────────────────────────────────────────────────────────────
# Get from https://megapay.co.ke/user/index → API Settings
MEGAPAY_BASE_URL=https://megapay.co.ke
MEGAPAY_API_KEY=your_megapay_api_key_here
MEGAPAY_EMAIL=your_megapay_account_email_here
MEGAPAY_CALLBACK_URL=https://www.nezeem.com/api/webhooks/megapay
MEGAPAY_CALLBACK_TOKEN=generate_a_strong_shared_secret

# ─── Crypto Deposit Addresses (HD Wallet) ────────────────────────────────────
# 12-word BIP39 mnemonic — KEEP SECRET, never commit the real value
MASTER_WALLET_MNEMONIC="word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12"

# Etherscan API V2 — covers ETH (chainId=1) and BSC (chainId=56)
# Get free key at https://etherscan.io/myapikey
ETHERSCAN_API_KEY=your_etherscan_api_key

# TronGrid — for TRC20 USDT deposits
# Get free key at https://www.trongrid.io/dashboard
TRONGRID_API_KEY=your_trongrid_api_key

# ─── Bet Settlement Cron / Workers ───────────────────────────────────────────
# Generate with: openssl rand -hex 32
# Used by VPS cron: curl -H "Authorization: Bearer YOUR_SECRET" https://nezeem.com/api/cron/check-deposits
CRON_SECRET=your_strong_random_secret_here
SETTLE_SECRET=your_polymarket_settlement_secret

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
